# Porta do servidor WhatsApp (Baileys)
PORT=3001

# URL do webhook do Laravel que recebe mensagens recebidas / status de conexão
LARAVEL_WEBHOOK_URL=http://localhost:8000/api/whatsapp/webhook

# 🔐 Chave de API obrigatória. Use o MESMO valor de BAILEYS_API_KEY no .env do Laravel.
# Gere um valor forte, por exemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=
